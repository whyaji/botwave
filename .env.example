# Server
PORT=8080
LOG_LEVEL=debug
NODE_ENV=development
APP_URL=http://localhost:8080

# Database
DB_URL=postgresql://user:password@localhost:5432/botwave

# JWT
JWT_SECRET=your-secret-key
JWT_EXPS=3600
JWT_REFRESH_EXPS=604800

# Password hashing (optional, default 10)
HASH_SALT=10

# Redis (for BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Legacy / optional
ACCESS_PRIVATE_KEY=your-private-key

# Seeder (optional)
SUPERADMIN_EMAIL=admin@botwave.local
SUPERADMIN_PASSWORD=SuperAdmin123!